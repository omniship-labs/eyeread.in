{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eyeread.in",
  "version": "0.1.0",
  "identifier": "in.eyeread.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/gen-dmg-background.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "eyeread.in",
        "url": "index.html",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0a0a0f"
      },
      {
        "label": "settings",
        "title": "Prompter settings",
        "url": "index.html?window=settings",
        "width": 300,
        "height": 480,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0a0a0f",
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "focus": true
      },
      {
        "label": "about",
        "title": "About eyeread.in",
        "url": "index.html?window=about",
        "width": 424,
        "height": 664,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "eyeread.in overlay",
        "url": "index.html?window=overlay",
        "width": 660,
        "height": 840,
        "acceptFirstMouse": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "contentProtected": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "visible": false,
        "visibleOnAllWorkspaces": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Invisible teleprompter",
    "longDescription": "eyeread.in floats your script as a translucent glass overlay on top of whatever you're sharing and stays invisible to screen-share and screen capture. Free, forever.",
    "publisher": "OmniShip",
    "copyright": "© OmniShip",
    "resources": {
      "icons/iconcomposer/actool-out/Assets.car": "Assets.car"
    },
    "macOS": {
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "11.0",
      "dmg": {
        "background": "../design/assets/dmg/dmg-background.tiff",
        "windowSize": { "width": 660, "height": 440 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "minimumWebview2Version": "110.0.1531.0"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGRjVCNTFCQzAwMDJGRjgKUldUNEx3REFHN1gxbjR6N1FEV2tWZEVRYnR3blI5YThlYjdrYVFXTWlTMTVjd3Z3OUladCt1SWUK",
      "endpoints": [
        "https://github.com/omniship-labs/eyeread.in/releases/latest/download/latest.json"
      ]
    }
  }
}
