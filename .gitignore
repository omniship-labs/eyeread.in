node_modules
.playwright-mcp
dist
src-tauri/target
src-tauri/gen
.DS_Store
*.local

# Private release/secrets notes — never meant for the public repo.
docs/RELEASING.local.md

# Sponsor avatars are downloaded at build time by scripts/fetch-sponsors.mjs.
# src/data/sponsors.json IS committed so the app import always resolves.
public/sponsors/

# Marketing site build output (Vite). Tokens + assets are imported from
# design/ at build time, so nothing is vendored here.
site/dist
# og-image.png is rasterized from design/ at build time (site/scripts/og-image.mjs)
site/public/og-image.png

# Playwright — captured screenshots + reports/traces are artifacts, not sources.
site/tests/screenshots/
test-results/
playwright-report/

# pre-commit hook's captured test output (.githooks/pre-commit) — JUnit XML
# + raw log, read only on failure, never meant to be committed.
.githooks/last-run/
