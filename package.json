{
  "name": "eyeread.in",
  "private": true,
  "version": "0.1.0",
  "description": "eyeread.in — free teleprompter that floats your script as a glass overlay, invisible to screen-share. Open source under AGPL-3.0.",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "sponsors": "node scripts/fetch-sponsors.mjs",
    "prebuild": "node scripts/fetch-sponsors.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "site:og": "node site/scripts/og-image.mjs",
    "site:dev": "npm run site:og && vite --config site/vite.config.js",
    "site:build": "npm run site:og && vite build --config site/vite.config.js && node site/scripts/prerender.mjs",
    "site:preview": "vite preview --config site/vite.config.js",
    "site:test": "playwright test",
    "site:test:update": "playwright test --update-snapshots",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/space-grotesk": "^5.2.5",
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify/react": "^6.0.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.0",
    "@tauri-apps/plugin-os": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "@tauri-apps/plugin-sql": "^2.3.0",
    "@tauri-apps/plugin-store": "^2.4.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.61.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tauri-apps/cli": "^2.11.3",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "prettier": "^3.6.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.0"
  }
}
